# Task Service — environment variables
# Copy to .env and adjust for local development

HOST=0.0.0.0:8080

# PostgreSQL
DATABASE_URL=postgres://dtms:dtms@localhost:5432/tasks
DATABASE_POOL_SIZE=10

# NATS
NATS_URL=nats://localhost:4222

# OpenTelemetry (OTLP gRPC)
OTLP_ENDPOINT=http://localhost:4317

# Logging — RUST_LOG syntax
LOG_LEVEL=task_service=debug,info

# Service name in traces
SERVICE_NAME=task-service
